#include <iostream>
#include <string>
using namespace std;

struct product
{
    int product_code;
    string product_name;
    int stock_count;
};

void display_shelf_report(const product store[][3], int aisle_count, int products_per_aisle)
{
    cout << "\n===== Shelf Stock Report =====\n";

    for(int i = 0; i < aisle_count; i++)
    {
        int total_stock = 0;

        cout << "\nAisle " << i+1 << ":\n";

        for(int j = 0; j < products_per_aisle; j++)
        {
            cout << store[i][j].product_code << " - "
                 << store[i][j].product_name
                 << " | Stock: "
                 << store[i][j].stock_count << endl;

            total_stock += store[i][j].stock_count;
        }

        cout << "Total Stock in Aisle " << i+1 << ": " << total_stock << endl;
        cout << "----------------------------\n";
    }
}

int main()
{
    product store[2][3];

    for(int i = 0; i < 2; i++)
    {
        cout << "\nEnter details for Aisle " << i+1 << endl;

        for(int j = 0; j < 3; j++)
        {
            cout << "Product " << j+1 << " Code: ";
            cin >> store[i][j].product_code;

            cout << "Product " << j+1 << " Name: ";
            cin >> store[i][j].product_name;

            cout << "Product " << j+1 << " Stock: ";
            cin >> store[i][j].stock_count;
        }
    }

    display_shelf_report(store, 2, 3);

    return 0;
}
